frontend/node_modules/
backend/node_modules/
extension/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 🔐 2. Variables de Entorno y Secretos (CRÍTICO)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
*.pem
*.key
*.cert

# 🏗️ 3. Builds de Producción
build/
dist/
frontend/dist/
backend/dist/
*.crx
*.zip
extension/*.zip

# 🗄️ 4. Bases de datos locales
*.sqlite
*.db

